{
  "name": "@codehz/auto-transition",
  "version": "0.0.7-13",
  "description": "A lightweight React component for automatic enter/exit/move transitions using Web Animations API",
  "license": "MIT",
  "author": "codehz",
  "module": "dist/index.mjs",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/codehz/auto-transition"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsdown": "^0.18.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./effects": {
      "types": "./dist/effects.d.mts",
      "import": "./dist/effects.mjs"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "prepare": "bunx husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "bunx tsdown --sourcemap --publint"
  },
  "tsdown": {
    "entry": {
      "index": "src/index.ts",
      "effects": "src/effects.ts"
    },
    "outputOptions": {
      "banner": "\"use client\";"
    }
  }
}
